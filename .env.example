# Copie este arquivo para .env e preencha os valores
# Para uso LOCAL: deixe DATABASE_URL em branco (usa SQLite automaticamente)
# Para PRODUÇÃO (Railway): cole a URL do PostgreSQL do Railway

# URL do banco PostgreSQL (Railway fornece isso)
# Exemplo: postgresql://postgres:senha@host.railway.app:5432/railway
DATABASE_URL=

# Porta local (opcional, padrão 8000)
PORT=8000
